{
  "capture_hotkey": "middle_click",
  "model": "docker.io/ai/gemma3:4B-F16",
  "ai_url": "http://localhost:12434",
  "settings_hotkey": "f12",
  "lens_settings_hotkey": "f11",
  "lens_hotkey_resize_width": "<ctrl>+<alt>+bracketright",
  "lens_hotkey_resize_height_up": "<ctrl>+<alt>+equals",
  "lens_hotkey_resize_height_down": "<ctrl>+<alt>+minus",
  "lens_wheel_mod_width": "shift",
  "lens_wheel_mod_height": "alt",
  "lens_shape": "circle",
  "lens_radius": 70,
  "lens_width": 140,
  "lens_height": 140,
  "lens_color": "#00f2ff",
  "lens_border_width": 1,
  "lens_opacity": 0.45,
  "popup_font_size": 14,
  "popup_auto_close_ms": 15000,
  "popup_opacity": 0.85,
  "popup_bg_color": "#1e1e1e",
  "popup_accent_color": "#00e6ff",
  "popup_translation_fg": "#ffffff",
  "popup_max_width": 480,
  "popup_border_radius": 10,
  "popup_border_width": 1,
  "popup_wrap_mode": "word",
  "popup_mouse_offset_x": 55,
  "popup_mouse_offset_y": 55,
  "exit_hotkey": "<shift>+q",
  "show_exit_button": true,
  "debug": false,
  "translate": {
    "prompt": "Translate the following English text to Thai. Reply with only the Thai translation, nothing else.\n\n{text}",
    "active_series": "default",
    "series_profiles": {
      "default": {
        "label": "Default",
        "context": "",
        "series_name": ""
      }
    }
  },
  "ai_ocr": {
    "enabled": false,
    "model": "docker.io/ai/gemma3n:2B-F16",
    "prompt": "Extract all text from this image exactly as it appears. Reply with only the extracted text, no explanations, no formatting.",
    "debug": false
  },
  "ocr": {
    "upscale": 2,
    "contrast": 1.0,
    "sharpness": 1.0,
    "binarize": false,
    "text_threshold": 0.5,
    "low_text": 0.3,
    "link_threshold": 0.3,
    "mag_ratio": 2.0,
    "min_size": 8,
    "fix_case": true,
    "debug": true
  },
  "setup_done": true
}
